# PROBLEM 1

### CODE

#include <stdio.h>

#define MAX 10

void getNumber(int *queue, int *size) {
    if (*size < MAX) {
        queue[*size] = 1;
        (*size)++;
    } else {
        printf("\nError! Cannot add to the queue.");
    }
}

void getNumberSenior(int *queue, int *size) {
    if (*size < MAX) {
        queue[*size] = 2;
        (*size)++;
    } else {
        printf("\nError! Cannot add to the queue.");
    }
}

void accommodate(int *queue, int *size) {
    int i;

    for (i = 0; i < *size; i++) {
        if (queue[i] == 2) {
            queue[i] = 0;
            return;
        }
    }
    
    for (i = 0; i < *size; i++) {
        if (queue[i] == 1) {
            queue[i] = 0;
            return;
        }
    }
    printf("\nQueue is empty.");
}

void showMenu(int *queue, int size) {
    printf("\nQueue: ");
    for (int i = 0; i < size; i++) {
        printf("%d ", queue[i]);
    }
    for (int i = size; i < 10; i++) {
        printf("%d ", 0);
    }
    
    printf("\n");
}


int main() {
    int queue[MAX] = {0};
    int size = 0;
    int choice;

    do {
        printf("\nMENU\n");
        printf("1. Get number\n");
        printf("2. Get number Senior\n");
        printf("3. Accommodate next number\n");
        printf("4. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                getNumber(queue, &size);
                showMenu(queue, size);
                break;
            case 2:
                getNumberSenior(queue, &size);
                showMenu(queue, size);
                break;
            case 3:
                accommodate(queue, &size);
                showMenu(queue, size);
                break;
            case 4:
                printf("\nThank you for queueing!\n");
                break;
            default:
                printf("\nInvalid choice!");
        }
    } while (choice != 4);

    return 0;
}


