#include <stdio.h>

#define MAX 10

void getNumber(int *queue, int *tail, int *count) {
    if (*count == MAX) {
        printf("\nError! Cannot add to the queue.");
        return;
    }

    queue[*tail] = 1;
    *tail = (*tail + 1) % MAX;
    (*count)++;
}

void getNumberSenior(int *queue, int *tail, int *count) {
    if (*count == MAX) {
        printf("\nError! Cannot add to the queue.");
        return;
    }

    queue[*tail] = 2;
    *tail = (*tail + 1) % MAX;
    (*count)++;
}

void accommodate(int *queue, int *head, int *tail, int *count) {
    if (*count == 0) {
        printf("\nQueue is empty.");
        return;
    }

    int tailIndex = (*tail - 1 + MAX) % MAX;
    
    int i; 
    for (i = 0; i < MAX; i++) { 
        if (queue[i] == 2) { 
            if (queue[*head] == 2) {
                queue[*head] = 0;
                *head = (*head + 1) % MAX;
            }
            else if (queue[tailIndex] == 2) {
                queue[tailIndex] = 0;
                *tail = tailIndex;
                *tail = (*tail)-i;
            } else {
                queue[i] = 0; 
            }
            (*count)--; 
            return; 
        }    
    }
    

        queue[*head] = 0;
        *head = (*head + 1) % MAX;
        (*count)--;
}

void showQueue(int *queue) {
    int i;
    printf("\nQueue: ");
    for (i = 0; i < MAX; i++) {
        printf("%d ", queue[i]);
    }
    printf("\n");
}

int main() {
    int queue[MAX] = {};
    int head = 0;
    int tail = 0;
    int count = 0;
    int choice;

    do {
        printf("\nMENU\n");
        printf("1. Get number\n");
        printf("2. Get number Senior\n");
        printf("3. Accommodate next number\n");
        printf("4. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                getNumber(queue, &tail, &count);
                showQueue(queue);
                break;
            case 2:
                getNumberSenior(queue, &tail, &count);
                showQueue(queue);
                break;
            case 3:
                accommodate(queue, &head, &tail, &count);
                showQueue(queue);
                break;
            case 4:
                printf("\nThank you for queueing!\n");
                break;
            default:
                printf("\nInvalid choice!");
        }
    } while (choice != 4);

    return 0;
}


