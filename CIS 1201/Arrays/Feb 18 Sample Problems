### PROBLEM 5: USE A VOID FUNCTION & POINTERS TO ADD 2 INTEGERS

#include <stdio.h>

void add(int *one, int *two) {
    *one += *two;
}

int main(int argc, char *argv[]) {
    int one = 5;
    int two = 10;
    printf("%d + %d", one, two);
    add(&one,&two);
    printf("\n%d", one);

    return 0;
}

OR

void sum (int *first, int second) {
    *first += second;
}

int main (int argc, char *argv[]) {
    int *first, second, temp;
    temp = 10;
    second = 20;
    first = &temp;
    sum(first, second);
    printf("%i", temp);

    return 0;
}
