### PROBLEM 4: PRINTING 1-100 WITHOUT LOOPS

#include <stdio.h>

int printIt(int current) {
    
    if (current > 100) {
        return 0;
    } else {
        printf("%i", current);
        printIt(++current);
    }
}

int main(int argc, char *argv[]) {
    printIt(1);
    return 0;
}


