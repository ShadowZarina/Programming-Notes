#include <stdio.h>
#include <string.h>

int my_strcmp(char *str1, char *str2) {
    int length = strlen(str1);
    for (int i = 0; i < length; i++) {
        if (*(str1+i) != *(str2+i)) {
            return -1;
        }
    }
    return 0;
}

