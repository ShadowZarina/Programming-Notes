#include <stdio.h>
#include <stdbool.h>
#include <ctype.h>

int main() {
    char low = 'a';
    char num = '4';
    char sym = '*';
    char str1[10] = "Andrea";
    char str3[10] = "abc123";

    bool is_digit = isdigit(num);
    bool is_alnum = isalnum(sym);
    bool is_upper = isupper(str1[0]);
    bool is_alpha = isalpha(str3[0]);
    bool str3_alnum = true;

    for (int i = 0; str3[i] != '\0'; i++) {
        if (!isalnum(str3[i])) {
            str3_alnum = false;
            break;
        }
    }

    printf("%s, %d\n", str1, is_digit);
    printf("%s, %d\n", str1, is_alnum);

    printf("%s, %d\n", str1, is_upper);
    printf("%s, %d\n", str3, is_alpha);


    str1[0] = tolower(str1[0]);
    printf("%s, %d\n", str1, isupper(str3[0]));


    str1[0] = toupper(str1[0]);
    printf("%s, %d\n", str1, isupper(str3[0]));

    printf("%d\n", str3_alnum);

    return 0;
}
