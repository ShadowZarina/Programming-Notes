## SAMPLE PROBLEM 1.1 (Struct with Function & Strcpy)


#include <stdio.h>
#include <stdlib.h>
struct Person
{
	int age;
	char name[20];
	char gender[20];
	char address[20];
};



struct Person getPersonInfo()
{
	struct Person Student1;
	Student1.age = 10;
	strcpy(Student1.name, "Alex");
	strcpy(Student1.gender, "Male");
	strcpy(Student1.address, "Cebu");
	
	return Student1;
}


main()
{
	struct Person x = getPersonInfo();
	printf("%i\n",x.age);
	printf("%s\n",x.name);
	printf("%s\n",x.gender);
	printf("%s\n",x.address);
	
}



## SAMPLE PROBLEM 1.2 (Struct with Function & Scanf)


#include <stdio.h>
#include <stdlib.h>

struct Person
{
	int age;
	char name[20];
	char gender[20];
	char address[20];
};

struct Person getPersonInfo()
{
	struct Person S;

	printf("Enter the student's age: ");
	scanf("%d", &S.age);
	printf("Enter the student's name: ");
	scanf("%s", &S.name);
	printf("Enter the student's gender: ");
	scanf("%s", &S.gender);
