# LOOPS

## FOR LOOPS

for (initialization; condition; increment/decrement)

## WHILE LOOPS

int x = 0;   --> INITIALIZATION
while (x <= 5) {   --> CONDITION
  printf("Hi\n");
  x++;   --> INCREMENT/DECREMENT
}

## DO-WHILE LOOPS

int x = 1;
do {
  printf("Hi\n";
} while (x < 5);

# POINTERS

Analogy: Using a 3rd glass to transfer liquids between 2 glasses

### EXAMPLE 1:

int x = 5, y = 10;
int z;  # Declare a new variable

z = y; 
y = x;
x = z;

### SAMPLE SOLUTION 1:

#include <stdio.h>


int swap (int *x, int *y) {
    int z;
    z = *x;
    *x = *y;
    *y = z;
    return *x, *y;
}

int main(){
    int x,y;
    
    printf("Enter the value of x: ");
    scanf("%d", &x);
    printf("Enter the value of y: ");
    scanf("%d", &y);
    swap(&x,&y);
    
    printf("%d is x, %d is y", x, y);
    return 0;
} 
# PASS THE ADDRESSES OF X AND Y TO THE FUNCTION, THE ACTUAL VARIABLES' VALUES WILL BE ALTERED

### EXAMPLE 2

#include <stdio.h>

int main(){
    int x = 5;
    int *ptr;
    ptr = &x;
    printf("%d", *ptr);
    printf("\n%p", &ptr);
    // Use ampersand for address, asterisk for value
    printf("\n%p", x);
    printf("\n%p", &x);
    // %p prints the memory address of a pointer in HEXADECIMAL FORMAT
    
    return 0;

/* OUTPUTS */
5
0x7ffd19d81720
0x5
0x7ffd19d8172c
}

